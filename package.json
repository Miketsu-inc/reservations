{
  "name": "reservations",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "workspaces": [
    "frontend/apps/*",
    "frontend/packages/*"
  ],
  "scripts": {
    "dev-jabulani": "vite --config frontend/apps/jabulani/vite.config.js --port 5173",
    "dev-tango": "vite --config frontend/apps/tango/vite.config.js --port 5174",
    "build-jabulani": "vite build --config frontend/apps/jabulani/vite.config.js",
    "build-tango": "vite build --config frontend/apps/tango/vite.config.js",
    "test": "vitest run",
    "lint": "eslint frontend --ext js,jsx --config frontend/eslint.config.js --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.170.3",
    "mapbox-gl": "^3.23.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@react-email/ui": "^6.1.4",
    "@tailwindcss/cli": "^4.3.0",
    "@tanstack/eslint-plugin-query": "^5.100.10",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@tanstack/router-plugin": "^1.168.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-classnames": "^0.10.1",
    "prettier-plugin-merge": "^0.10.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-email": "^6.1.4",
    "tailwindcss": "^4.3.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.6"
  }
}
